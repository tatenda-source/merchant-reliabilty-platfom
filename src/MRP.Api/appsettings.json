{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Paynow": {
    "DefaultResultUrl": "https://mrp.paynow.co.zw/api/webhooks/paynow",
    "PollIntervalSeconds": 900,
    "MaxConcurrentPolls": 10,
    "MaxRetryAttempts": 3
  },
  "AllowedHosts": "*"
}
